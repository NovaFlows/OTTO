# ════════════════════════════════════════
#  Otto Shop — Variables d'environnement
#  Copier ce fichier en .env.local et remplir les valeurs
# ════════════════════════════════════════

# ── Supabase ──────────────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Stripe ────────────────────────────
# Stripe → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Stripe → Webhooks → votre endpoint → Signing secret
# Endpoint : https://ottodrewit.com/api/webhooks/stripe
# Événement à écouter : checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend ────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...

# Domaine vérifié dans Resend
EMAIL_FROM=commandes@ottodrewit.com
EMAIL_OTTO=otto@ottodrewit.com

# ── App ───────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ottodrewit.com
# En développement : http://localhost:3000
